---
export interface Props {
    title?: string;
}
const { title } = Astro.props;
---

<div class="definition">
    <div class="definition-header">
        <span class="definition-label"
            >Definition <span class="definition-number">:</span></span
        >
        {title && <span class="definition-title">({title}) </span>}
    </div>
    <div class="definition-body">
        <slot />
    </div>
</div>

<style>
    .definition {
        margin: 1.5rem 0;
        padding: 1rem 1.5rem;
        border-left: 7px solid rgb(255, 95, 31);
        background-color: rgba(255, 95, 31, 0.2);
        border-radius: 2px;
        counter-increment: definition-counter;
    }

    .definition-header {
		margin-bottom: 0.6rem;
        color: rgba(255, 95, 31);
        font-weight: 700;
        font-size: 1.3rem;
    }

    .definition-body {
        display: inline;
        font-weight: normal;
        font-style: normal;
    }

    .definition-number::before {
        content: counter(definition-counter);
    }

    .definition-title {
        font-weight: normal;
        font-style: italic;
    }
</style>
